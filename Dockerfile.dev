# Dev image: install deps once; source is bind-mounted at runtime (see docker-compose.dev.yml).
FROM node:18-bullseye
WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=development
EXPOSE 3000

# Default; compose overrides with explicit -H for Docker networking.
CMD ["npx", "next", "dev", "-H", "0.0.0.0", "-p", "3000"]
