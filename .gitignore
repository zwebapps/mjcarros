# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Environment variables (never commit real secrets)
.env.local
.env.local.*
.env.build
.env.docker
prd.env
.env.production

# User uploads (images, PDFs) — never commit binaries; only .gitkeep preserves folders in git.
# Order matters: un-ignore a directory before un-ignoring files inside it.
public/uploads/*
!public/uploads/.gitkeep

!public/uploads/product/
public/uploads/product/*
!public/uploads/product/.gitkeep

!public/uploads/category/
public/uploads/category/*
!public/uploads/category/.gitkeep

!public/uploads/vouchers/
public/uploads/vouchers/*
!public/uploads/vouchers/.gitkeep

!public/uploads/seed/
public/uploads/seed/*
!public/uploads/seed/.gitkeep
data/order-backups/
