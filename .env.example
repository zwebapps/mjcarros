# Copy to `.env` or `.env.local` and fill in values. Do not commit filled files.

# Optional: set to 1 only for `next build` when no DB vars exist (e.g. Docker image build). Runtime must use real credentials.
# SKIP_DB_ENV_VALIDATION=

# --- MongoDB (use DATABASE_URL **or** the discrete variables below) ---
# DATABASE_URL=mongodb://USER:PASSWORD@localhost:27017/YOUR_DB?authSource=YOUR_DB
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_HOST=localhost
MONGO_PORT=27017
# Required when not using DATABASE_URL; must match DB name used in init / connection string
MONGO_DATABASE=
MONGO_AUTH_SOURCE=

# Root user (for setup-admin when not using DATABASE_URL)
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# First admin (setup-admin / Docker entrypoint)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Optional: seed a test user (omit in production)
# TEST_USER_PASSWORD=
# TEST_USER_EMAIL=test@mjcarros.com

# --- Auth ---
JWT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# --- Email ---
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- Storage ---
# This project stores uploaded images under `public/uploads/` and serves them as `/uploads/...`.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
DOCKER=

# --- VPS / production (docker-compose.prod.yml — default for deploy) ---
# Prod compose maps host 8080 → app 3000. Put nginx/Caddy in front for HTTPS.
#
# Optional: docker-compose.ionos.yml uses IONOS_HTTP_PORT instead:
# IONOS_HTTP_PORT=8080
